{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "pre-commit": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^terraform\\/cluster-bootstrap\\/main\\.tf$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*[a-zA-Z0-9_]+\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "{{{datasource}}}",
      "depNameTemplate": "{{{depName}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^terraform\\/cluster-bootstrap\\/main\\.tf$/"],
      "matchStrings": [
        "repository\\s*=\\s*\"(?<registryUrl>https?://[^\"]+)\"\\s*\\n\\s*chart\\s*=\\s*\"(?<depName>[^\"]+)\"\\s*\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "{{{depName}}}",
      "registryUrlTemplate": "{{{registryUrl}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^terraform\\/cluster-bootstrap\\/main\\.tf$/"],
      "matchStrings": [
        "repository\\s*=\\s*\"oci://(?<registryPath>[^\"]+)\"\\s*\\n\\s*chart\\s*=\\s*\"(?<chartName>[^\"]+)\"\\s*\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "{{{registryPath}}}/{{{chartName}}}",
      "versioningTemplate": "helm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^gitops\\/.+\\/app(?:\\.suppress)?\\.yaml$/"],
      "matchStrings": [
        "chart:\\s*(?<depName>\\S+)\\s*\\nrepoURL:\\s*(?<registryUrl>https?://\\S+)\\s*\\n(?:\\s*#.*\\n)*targetRevision:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "{{{depName}}}",
      "registryUrlTemplate": "{{{registryUrl}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^gitops\\/.+\\/app(?:\\.suppress)?\\.yaml$/"],
      "matchStrings": [
        "repoURL:\\s*oci://(?<depName>\\S+)\\s*\\n(?:\\s*#.*\\n)*targetRevision:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "{{{depName}}}",
      "versioningTemplate": "helm"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["helm", "docker"],
      "groupName": "helm chart releases"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["github-releases"],
      "groupName": "cluster bootstrap releases"
    },
    {
      "matchManagers": ["terraform"],
      "groupName": "terraform dependencies"
    },
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    }
  ]
}
